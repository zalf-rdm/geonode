# #################
# Dev environment overrides
# Only values that differ from the root .env
# #################

# Enable debug for development
DEBUG=True
DEBUG_STATIC=True

# ZALF custom metadata template
CATALOG_METADATA_TEMPLATE=catalogue/zalf_metadata.xml
COMPOSE_PROJECT_NAME=geonode
DOCKER_ENV=development

# Advanced Workflow
RESOURCE_PUBLISHING=False
ADMIN_MODERATE_UPLOADS=False

ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
ADMIN_EMAIL=admin@localhost

DEBUG=True
DEBUG_STATIC=True

CATALOG_METADATA_TEMPLATE="catalogue/zalf_metadata.xml"

CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://localhost:8081
